rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /t2t_avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /t2t_courses/{courseId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /t2t_certificates/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
