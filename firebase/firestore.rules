rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // =============================================================================
    // Lo HAgo Facil: bookings
    // =============================================================================
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // =============================================================================
    // T2T Academy — colecciones con prefijo t2t_
    // (Cuando quites el match recursivo de desarrollo abajo, estas reglas quedan como producción.)
    // =============================================================================

    match /t2t_users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    match /t2t_diagnostic_results/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /t2t_progress/{uid}/t2t_user_courses/{courseId} {
      allow read, write: if isOwner(uid);
    }

    match /t2t_enrollments/{id} {
      allow read, write: if isSignedIn() && (resource == null
        ? request.resource.data.userId == request.auth.uid
        : resource.data.userId == request.auth.uid);
    }

    match /t2t_notifications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /t2t_courses/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_skills/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_plans/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_modules/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_lessons/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_subscriptions/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /t2t_subscription_codes/{code} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /t2t_coins_transactions/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /t2t_achievements/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /t2t_weekly_challenges/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /t2t_subscription_redemptions/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // =============================================================================
    // TEMPORAL — desarrollo: cualquier usuario autenticado puede leer/escribir
    // el resto de colecciones no cubiertas arriba (incluye otras apps / pruebas).
    // Quitar o endurecer antes de producción.
    // =============================================================================
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
