# Copiar a .env y completar valores (Expo / Metro)

EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=

# OAuth Client ID tipo Web (NO el Android): en google-services.json → oauth_client con "client_type": 3
# Ejemplo questly-flutter / com.t2tacademy.app: ...-8oqedbuneoseqo18i0jcegffl2dk03fg.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Opcional: push Expo (project UUID en expo.dev)
EXPO_PUBLIC_EAS_PROJECT_ID=

