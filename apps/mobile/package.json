{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android && node ./scripts/sync-google-services.cjs && node ./scripts/setup-android-signing.cjs",
    "setup:android-signing": "node ./scripts/setup-android-signing.cjs",
    "bundle:android": "node ./scripts/setup-android-signing.cjs && cd android && gradlew.bat bundleRelease",
    "prebuild:ios": "expo prebuild --platform ios",
    "sync-google-services": "node ./scripts/sync-google-services.cjs",
    "android:sha1": "node ./scripts/print-android-sha1.cjs",
    "android:sha1:release": "node ./scripts/print-android-release-sha1.cjs",
    "ios:google-config": "node ./scripts/print-ios-google-config.cjs",
    "generate:icons": "node ./scripts/generate-app-icon.cjs",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.13",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.15",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.11",
    "expo-linear-gradient": "~55.0.8",
    "expo-navigation-bar": "~55.0.13",
    "expo-notifications": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-video": "~3.0.0",
    "expo-web-browser": "~55.0.16",
    "firebase": "^12.10.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
