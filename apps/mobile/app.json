{
  "expo": {
    "name": "T2T Academy",
    "slug": "t2t-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "t2tacademy",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1D083A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.t2tacademy.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.t2tacademy.mobile",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1D083A"
      },
      "navigationBar": {
        "backgroundColor": "#1D083A",
        "barStyle": "light-content"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      "expo-video",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "T2T Academy necesita acceso a tus fotos para actualizar tu perfil."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.34025167590-3lvtk9irp9pdrv33hm1lo771paalcavt"
        }
      ],
      "expo-web-browser",
      "./plugins/withGoogleServicesAndroid.js",
      "./plugins/withAndroidReleaseSigning.js"
    ],
    "extra": {
      "eas": {
        "projectId": "202571bd-feab-43c3-9eb0-ef2a2ce0bc63"
      }
    },
    "owner": "chillpenguin222"
  }
}
