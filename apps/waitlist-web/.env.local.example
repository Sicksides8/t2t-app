# Firebase Admin (mismo proyecto que mobile / CRM)
# En desarrollo, Next carga automáticamente apps/web-crm/.env si existe.
FIREBASE_PROJECT_ID=questly-flutter
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=questly-flutter.firebasestorage.app

# Resend
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=onboarding@resend.dev
WAITLIST_FROM_NAME=T2T Academy

# Enlaces a las tiendas
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.t2tacademy.app
APP_STORE_URL=

# Panel /admin (Basic Auth)
MAILER_ADMIN_USER=admin
MAILER_ADMIN_PASSWORD=cambiar-en-produccion

# Rate limit
WAITLIST_RATE_LIMIT_MAX=5
WAITLIST_RATE_LIMIT_WINDOW_MINUTES=60

# Orígenes extra para POST /api/waitlist (opcional en Netlify: URL del sitio se detecta sola)
WAITLIST_ALLOWED_ORIGINS=http://localhost:3001,https://t2t-wlist.netlify.app
